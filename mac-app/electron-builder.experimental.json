{
  "appId": "com.fieldtheory.experimental",
  "productName": "Field Theory Experimental",
  "beforeBuild": "scripts/electron-builder-before-build.js",
  "mac": {
    "category": "public.app-category.productivity",
    "minimumSystemVersion": "13.0",
    "target": [
      "dmg",
      "zip"
    ],
    "icon": "electron/assets/icon.icns",
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "extendInfo": {
      "LSUIElement": true,
      "NSMicrophoneUsageDescription": "Field Theory needs microphone access to transcribe your voice into text.",
      "NSCameraUsageDescription": "Used locally to detect gaze direction for window focus. No video is recorded or transmitted.",
      "NSScreenCaptureDescription": "Field Theory needs screen recording permission to capture screenshots and system audio for AI context.",
      "NSAppleEventsUsageDescription": "Field Theory needs automation permission to paste transcribed text into other applications."
    },
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "extraResources": [
      {
        "from": "electron/native/build/FieldTheoryHelper",
        "to": "FieldTheoryHelper"
      },
      {
        "from": "electron/assets",
        "to": "assets"
      },
      {
        "from": "../build-whisper/bin/whisper-cli",
        "to": "whisper-cli"
      },
      {
        "from": "../build-whisper/bin/whisper-server",
        "to": "whisper-server"
      },
      {
        "from": "public/sounds",
        "to": "sounds"
      },
      {
        "from": "resources/chatterbox",
        "to": "chatterbox"
      },
      {
        "from": "scripts/find-mlx-python.sh",
        "to": "scripts/find-mlx-python.sh"
      },
      {
        "from": "scripts/mlx-whisper-transcribe.py",
        "to": "scripts/mlx-whisper-transcribe.py"
      },
      {
        "from": "scripts/setup-mlx-whisper.sh",
        "to": "scripts/setup-mlx-whisper.sh"
      },
      {
        "from": "scripts/parakeet-transcribe.py",
        "to": "scripts/parakeet-transcribe.py"
      },
      {
        "from": "scripts/setup-parakeet.sh",
        "to": "scripts/setup-parakeet.sh"
      }
    ]
  },
  "files": [
    "dist/**/*",
    "electron-dist/**/*",
    "package.json",
    "node_modules/**/*",
    "!electron-dist/**/*.test.js",
    "!electron-dist/**/*.test.js.map",
    "!node_modules/.cache/**/*",
    "!node_modules/.bin/**/*",
    "!node_modules/@dnd-kit{,/**/*}",
    "!node_modules/@electron{,/**/*}",
    "!node_modules/@excalidraw{,/**/*}",
    "!node_modules/@node-llama-cpp{,/**/*}",
    "!node_modules/@testing-library{,/**/*}",
    "!node_modules/@types{,/**/*}",
    "!node_modules/@types/better-sqlite3{,/**/*}",
    "!node_modules/@vitejs{,/**/*}",
    "!node_modules/@vitest{,/**/*}",
    "!node_modules/app-builder-bin{,/**/*}",
    "!node_modules/app-builder-lib{,/**/*}",
    "!node_modules/baseline-browser-mapping{,/**/*}",
    "!node_modules/concurrently{,/**/*}",
    "!node_modules/cytoscape{,/**/*}",
    "!node_modules/date-fns{,/**/*}",
    "!node_modules/electron{,/**/*}",
    "!node_modules/electron-builder{,/**/*}",
    "!node_modules/electron-rebuild{,/**/*}",
    "!node_modules/elkjs{,/**/*}",
    "!node_modules/happy-dom{,/**/*}",
    "!node_modules/katex{,/**/*}",
    "!node_modules/lzma-native{,/**/*}",
    "!node_modules/mermaid{,/**/*}",
    "!node_modules/node-llama-cpp{,/**/*}",
    "!node_modules/react{,/**/*}",
    "!node_modules/react-dom{,/**/*}",
    "!node_modules/react-markdown{,/**/*}",
    "!node_modules/typescript{,/**/*}",
    "!node_modules/vite{,/**/*}",
    "!node_modules/vitest{,/**/*}",
    "!node_modules/wait-on{,/**/*}"
  ],
  "directories": {
    "output": "release-experimental"
  }
}
