{
  "appId": "com.fieldtheory.experimental",
  "productName": "Field Theory Experimental",
  "beforeBuild": "scripts/electron-builder-before-build.js",
  "mac": {
    "category": "public.app-category.productivity",
    "minimumSystemVersion": "13.0",
    "target": [
      "dmg",
      "zip"
    ],
    "icon": "assets/icon.icns",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "extraResources": [
      {
        "from": "electron/native/build/FieldTheoryHelper",
        "to": "FieldTheoryHelper"
      },
      {
        "from": "electron/assets",
        "to": "assets"
      },
      {
        "from": "../../build-whisper/bin/whisper-cli",
        "to": "whisper-cli"
      },
      {
        "from": "scripts/qwen-transcribe.py",
        "to": "scripts/qwen-transcribe.py"
      },
      {
        "from": "scripts/setup-qwen.sh",
        "to": "scripts/setup-qwen.sh"
      }
    ]
  },
  "files": [
    "dist/**/*",
    "electron-dist/**/*"
  ],
  "directories": {
    "output": "release-experimental"
  }
}
