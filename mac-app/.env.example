# Field Theory Mac local development environment.
# Copy this file to .env.local and edit values only for the surfaces you are testing.

# Optional Supabase account-backed features.
# Core local workflows should run without these values.
VITE_SUPABASE_URL=
FIELD_THEORY_SUPABASE_PUBLISHABLE_KEY=

# Backward-compatible alias used by some renderer/main code paths.
VITE_SUPABASE_ANON_KEY=

# Optional password reset URL used by auth flows.
VITE_PASSWORD_RESET_URL=

# Optional build channel for local experiments.
# Normal contributors should leave this unset.
# FIELD_THEORY_BUILD_CHANNEL=experimental
# VITE_FIELD_THEORY_BUILD_CHANNEL=experimental
# EXPERIMENTAL=true

# Optional internal sync gate.
# Leave disabled unless intentionally testing internal Library/command sync behavior.
# FIELD_THEORY_INTERNAL_SYNC_ENABLED=false

# Optional local protocol registration for development.
# FT_REGISTER_FIELD_THEORY_PROTOCOL=true

# Maintainer-only release/update credentials are intentionally not included here:
# GH_TOKEN
# APPLE_ID
# APPLE_ID_PASSWORD
# APPLE_TEAM_ID
# FIELD_THEORY_EXPERIMENTAL_UPDATE_TOKEN
