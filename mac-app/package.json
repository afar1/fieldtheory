{
  "name": "littleai-mac",
  "version": "0.1.34",
  "private": true,
  "main": "electron-dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "npm run build:electron && wait-on tcp:5173 && ELECTRON_START_URL=http://localhost:5173 electron .",
    "dev:experimental": "EXPERIMENTAL=true npm run dev",
    "build": "npm run build:electron && npm run build:vite",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:native": "cd electron/native && swift build -c release && mkdir -p build && cp .build/release/LittleOneHelper build/ && codesign --force --deep --sign - build/LittleOneHelper",
    "build:whisper": "scripts/build-whisper.sh",
    "build:all": "npm run build:native && npm run build:whisper && npm run build",
    "build:experimental": "EXPERIMENTAL=true npm run build",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "start": "electron .",
    "package": "npm run build:all && electron-builder",
    "package:experimental": "npm run build:all && electron-builder --config electron-builder.experimental.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@excalidraw/excalidraw": "^0.18.0",
    "@supabase/supabase-js": "^2.84.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.5.0",
    "electron-updater": "^6.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.2",
    "@types/node": "^20.11.19",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^8.2.2",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.fieldtheory.app",
    "productName": "Field Theory",
    "afterSign": "scripts/notarize.js",
    "publish": {
      "provider": "github",
      "owner": "afar1",
      "repo": "field-releases"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "notarize": {
        "teamId": "3244UJ94D8"
      },
      "minimumSystemVersion": "13.0",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extraResources": [
        {
          "from": "electron/native/build/LittleOneHelper",
          "to": "LittleOneHelper"
        },
        {
          "from": "electron/assets",
          "to": "assets"
        },
        {
          "from": "../build-whisper/bin/whisper-cli",
          "to": "whisper-cli"
        },
        {
          "from": "electron/main/prompts",
          "to": "prompts"
        },
        {
          "from": "public/sounds",
          "to": "sounds"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
