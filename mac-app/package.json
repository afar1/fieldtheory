{
  "name": "fieldtheory-mac",
  "version": "0.1.108",
  "private": true,
  "main": "electron-dist/main/index.js",
  "scripts": {
    "dev": "npm run dev:quiet",
    "dev:quiet": "concurrently --raw -k \"npm:dev:vite:quiet\" \"npm:dev:electron:quiet\"",
    "dev:active": "concurrently --raw -k \"npm:dev:vite:quiet\" \"npm:dev:electron:active\"",
    "dev:verbose": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron:verbose\"",
    "dev:vite": "vite",
    "dev:vite:quiet": "vite --logLevel warn",
    "dev:electron": "npm run build:electron && wait-on tcp:5173 && ELECTRON_START_URL=http://localhost:5173 electron .",
    "dev:electron:quiet": "npm run build:electron --silent && wait-on tcp:5173 && LOG_LEVEL=warn ELECTRON_START_URL=http://localhost:5173 electron .",
    "dev:electron:active": "npm run build:electron --silent && wait-on tcp:5173 && LOG_LEVEL=warn LOG_ACTIVE_COMPONENTS_FILE=.active-components LOG_ACTIVE_FILE=.logs/active-debug.log LOG_ACTIVE_RESET=true ELECTRON_START_URL=http://localhost:5173 electron .",
    "dev:electron:verbose": "npm run build:electron && wait-on tcp:5173 && LOG_LEVEL=debug ELECTRON_START_URL=http://localhost:5173 electron .",
    "dev:experimental": "EXPERIMENTAL=true npm run dev",
    "dev:mock": "VITE_MOCK=$MOCK npm run dev",
    "build": "npm run build:electron && npm run build:vite",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:native": "cd electron/native && swift build -c release && mkdir -p build && cp .build/release/FieldTheoryHelper build/ && codesign --force --deep --sign - build/FieldTheoryHelper",
    "build:whisper": "scripts/build-whisper.sh",
    "build:all": "npm run build:native && npm run build:whisper && npm run build",
    "build:experimental": "EXPERIMENTAL=true npm run build",
    "guard:tracked-sources": "bash scripts/check-untracked-source.sh",
    "rebuild": "electron-rebuild -f -w better-sqlite3,node-llama-cpp",
    "postinstall": "electron-rebuild -f -w better-sqlite3,node-llama-cpp",
    "start": "electron .",
    "package": "npm run guard:tracked-sources && npm run build:all && electron-builder",
    "package:experimental": "npm run guard:tracked-sources && npm run build:all && electron-builder --config electron-builder.experimental.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@excalidraw/excalidraw": "^0.18.0",
    "@supabase/supabase-js": "^2.84.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react-window": "^1.8.8",
    "agentmail": "^0.4.9",
    "baseline-browser-mapping": "^2.9.19",
    "better-sqlite3": "^12.5.0",
    "chokidar": "^3.6.0",
    "electron-updater": "^6.6.2",
    "fs-extra": "^11.3.3",
    "imapflow": "^1.2.15",
    "node-llama-cpp": "^3.15.0",
    "nodemailer": "^8.0.3",
    "plist": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-window": "^2.2.7",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.2",
    "@testing-library/react": "^16.3.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.19",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.0.17",
    "concurrently": "^8.2.2",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "happy-dom": "^20.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^4.0.17",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.fieldtheory.app",
    "productName": "Field Theory",
    "beforeBuild": "scripts/electron-builder-before-build.js",
    "afterSign": "scripts/notarize.js",
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "ext": "markdown",
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "ext": "mdx",
        "name": "MDX",
        "description": "MDX document",
        "role": "Editor",
        "rank": "Alternate"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "afar1",
      "repo": "field-releases"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "notarize": false,
      "minimumSystemVersion": "13.0",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "LSUIElement": true,
        "NSMicrophoneUsageDescription": "Field Theory needs microphone access to transcribe your voice into text.",
        "NSScreenCaptureDescription": "Field Theory needs screen recording permission to capture screenshots and system audio for AI context.",
        "NSAppleEventsUsageDescription": "Field Theory needs automation permission to paste transcribed text into other applications."
      },
      "extraResources": [
        {
          "from": "electron/native/build/FieldTheoryHelper",
          "to": "FieldTheoryHelper"
        },
        {
          "from": "electron/assets",
          "to": "assets"
        },
        {
          "from": "../build-whisper/bin/whisper-cli",
          "to": "whisper-cli"
        },
        {
          "from": "../build-whisper/bin/whisper-server",
          "to": "whisper-server"
        },
        {
          "from": "public/sounds",
          "to": "sounds"
        },
        {
          "from": "resources/chatterbox",
          "to": "chatterbox"
        },
        {
          "from": "scripts/find-mlx-python.sh",
          "to": "scripts/find-mlx-python.sh"
        },
        {
          "from": "scripts/mlx-whisper-transcribe.py",
          "to": "scripts/mlx-whisper-transcribe.py"
        },
        {
          "from": "scripts/setup-mlx-whisper.sh",
          "to": "scripts/setup-mlx-whisper.sh"
        },
        {
          "from": "scripts/parakeet-transcribe.py",
          "to": "scripts/parakeet-transcribe.py"
        },
        {
          "from": "scripts/setup-parakeet.sh",
          "to": "scripts/setup-parakeet.sh"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "package.json",
      "node_modules/**/*",
      "!electron-dist/**/*.test.js",
      "!electron-dist/**/*.test.js.map",
      "!node_modules/.cache/**/*",
      "!node_modules/.bin/**/*",
      "!node_modules/@dnd-kit{,/**/*}",
      "!node_modules/@electron{,/**/*}",
      "!node_modules/@excalidraw{,/**/*}",
      "!node_modules/@node-llama-cpp{,/**/*}",
      "!node_modules/@testing-library{,/**/*}",
      "!node_modules/@types{,/**/*}",
      "!node_modules/@types/better-sqlite3{,/**/*}",
      "!node_modules/@vitejs{,/**/*}",
      "!node_modules/@vitest{,/**/*}",
      "!node_modules/app-builder-bin{,/**/*}",
      "!node_modules/app-builder-lib{,/**/*}",
      "!node_modules/baseline-browser-mapping{,/**/*}",
      "!node_modules/concurrently{,/**/*}",
      "!node_modules/cytoscape{,/**/*}",
      "!node_modules/date-fns{,/**/*}",
      "!node_modules/electron{,/**/*}",
      "!node_modules/electron-builder{,/**/*}",
      "!node_modules/electron-rebuild{,/**/*}",
      "!node_modules/elkjs{,/**/*}",
      "!node_modules/happy-dom{,/**/*}",
      "!node_modules/katex{,/**/*}",
      "!node_modules/lzma-native{,/**/*}",
      "!node_modules/mermaid{,/**/*}",
      "!node_modules/node-llama-cpp{,/**/*}",
      "!node_modules/react{,/**/*}",
      "!node_modules/react-dom{,/**/*}",
      "!node_modules/react-markdown{,/**/*}",
      "!node_modules/typescript{,/**/*}",
      "!node_modules/vite{,/**/*}",
      "!node_modules/vitest{,/**/*}",
      "!node_modules/wait-on{,/**/*}"
    ],
    "directories": {
      "output": "release"
    }
  }
}
