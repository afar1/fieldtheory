{
  "name": "fieldtheory",
  "version": "1.0.0",
  "description": "Field Theory app source workspace.",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afar1/fieldtheory.git"
  },
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test:library-text": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test tests/libraryText.test.mjs tests/libraryHash.test.mjs tests/librarySync.test.mjs",
    "test:mobile-regressions": "cd mac-app && npm run test -- src/__tests__/syncUtils.test.ts src/__tests__/mobileStorage.test.ts src/__tests__/mobileCommands.test.ts src/__tests__/mobileTranscriptCapture.test.ts src/__tests__/mobileLibraryState.test.ts",
    "verify:ios-public-readiness": "bash scripts/verify-ios-public-readiness.sh",
    "inspect:ios-archive": "bash scripts/inspect-ios-archive.sh"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@supabase/supabase-js": "^2.84.0",
    "expo": "~52.0.49",
    "expo-asset": "~11.0.5",
    "expo-audio": "~0.3.5",
    "expo-clipboard": "~7.0.1",
    "expo-crypto": "~14.0.2",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-image-manipulator": "~13.0.6",
    "expo-status-bar": "~2.0.0",
    "expo-web-browser": "~14.0.2",
    "react": "18.3.1",
    "react-native": "^0.76.9",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-get-random-values": "^1.11.0",
    "react-native-pager-view": "6.5.1",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-webview": "13.12.5",
    "whisper.rn": "^0.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@react-native-community/cli": "^20.0.2",
    "@types/react": "~18.3.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13",
    "postcss": "8.5.14",
    "tar": "7.5.15"
  }
}
